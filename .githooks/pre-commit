#!/usr/bin/env sh

# Blocks commits that modify protected script paths unless an explicit override is set.
# Override intentionally when needed:
#   ALLOW_PROTECTED_SCRIPT_CHANGES=1 git commit -m "..."

if [ "${ALLOW_PROTECTED_SCRIPT_CHANGES:-0}" = "1" ]; then
  exit 0
fi

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$staged_files" ]; then
  exit 0
fi

protected_matches="$(printf '%s\n' "$staged_files" | grep -E '^(main\.py|toolkit/|scripts/)' || true)"

if [ -n "$protected_matches" ]; then
  echo "[LOCKED] Commit blocked: protected script paths changed."
  echo ""
  echo "Protected paths:"
  echo "  - main.py"
  echo "  - toolkit/*"
  echo "  - scripts/*"
  echo ""
  echo "Staged protected files:"
  printf '%s\n' "$protected_matches"
  echo ""
  echo "If this change is intentional, commit with override:"
  echo "  ALLOW_PROTECTED_SCRIPT_CHANGES=1 git commit -m \"your message\""
  exit 1
fi

exit 0
