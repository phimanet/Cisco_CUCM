# Twilio lookup configuration for CUCM web portal
# Copy these values into your /opt/cucm-web/.env file on the server.
# Do not commit real secrets.

# Required: Parent Twilio account credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Recommended for your setup: set subaccount SID directly (fastest and exact)
TWILIO_SUBACCOUNT_SID=ACyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Optional fallback if SID is not provided.
# The app will search subaccounts by this friendly name and use the first active match.
TWILIO_SUBACCOUNT_NAME=AMNOne-Notification-PROD
